# ESP32-S3 配置: 8MB Flash + 16MB PSRAM
# 使用 idf.py reconfigure 应用此配置

# Flash 大小: 8MB
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="8MB"

# PSRAM: 16MB (Quad模式, 80MHz)
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_QUAD=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_BOOT_INIT=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y
CONFIG_SPIRAM_ALLOW_BSS_SEG_EXTERNAL_MEMORY=y

# 分区表: 使用适合 8MB Flash 的大分区表
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_8mb.csv"

# ============================================================
#  IRAM 优化 (解决 IRAM 100% 占满)
# ============================================================

# 关闭 WiFi 日志 (减少 IRAM 占用)
CONFIG_LOG_DEFAULT_LEVEL_WARN=y
CONFIG_LOG_DEFAULT_LEVEL=2

# 关闭不必要的 WiFi 调试功能
CONFIG_ESP_WIFI_STA_DISCONNECTED_PM_ENABLE=n
CONFIG_ESP_WIFI_SOFTAP_SUPPORT=n

# 优化 FreeRTOS: 不强制将所有任务栈放入 IRAM
CONFIG_FREERTOS_TASK_FUNCTION_WRAPPER=n
CONFIG_FREERTOS_CHECK_STACKOVERFLOW_NONE=y

# 关闭 core dump (释放 IRAM)
CONFIG_ESP_COREDUMP_ENABLE=n

# 关闭不需要的 ADC 调试
CONFIG_ADC_DISABLE_DAC=y
